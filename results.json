      "responseBody": "\r\n<!DOCTYPE html>\r\n<html>\r\n<head>\r\n    <title>3D Secure Doğrulama (MOCK)</title>\r\n    <style>\r\n        body { font-family: Arial; max-width: 500px; margin: 50px auto; padding: 20px; }\r\n        h2 { color: #333; }\r\n        .btn { padding: 10px 20px; margin: 10px; cursor: pointer; border: none; border-radius: 5px; }\r\n        .success { background: #4CAF50; color: white; }\r\n        .fail { background: #f44336; color: white; }\r\n    </style>\r\n</head>\r\n<body>\r\n    <h2>🔒 3D Secure Doğrulama (MOCK)</h2>\r\n    <p><strong>Transaction ID:</strong> test-tx-id</p>\r\n    <p>Bu bir mock 3D Secure sayfasıdır. Gerçek bankadan gelmiyoruz.</p>\r\n    <hr>\r\n    <button class='btn success' onclick=\"completePayment(true)\">✅ Ödemeyi Onayla</button>\r\n    <button class='btn fail' onclick=\"completePayment(false)\">❌ Ödemeyi Reddet</button>\r\n\r\n    <script>\r\n        async function completePayment(success) {\r\n            try {\r\n                const response = await fetch('/api/payments/3dsecure/callback', {\r\n                    method: 'POST',\r\n                    headers: { 'Content-Type': 'application/json' },\r\n                    body: JSON.stringify({\r\n                        transactionId: 'test-tx-id',\r\n                        success: success,\r\n                        threeDSecureResult: success ? 'APPROVED' : 'DECLINED'\r\n                    })\r\n                });\r\n\r\n                const data = await response.json();\r\n                \r\n                if (data.success) {\r\n                    alert('✅ Ödeme başarılı! Transaction ID: ' + data.transactionId);\r\n                    window.close();\r\n                } else {\r\n                    alert('❌ Ödeme başarısız: ' + data.message);\r\n                }\r\n            } catch (error) {\r\n                alert('Hata: ' + error.message);\r\n            }\r\n        }\r\n    </script>\r\n</body>\r\n</html>",
